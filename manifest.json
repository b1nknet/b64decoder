{
  "manifest_version": 3,
  "name": "Base64 Decoder",
  "version": "1.0.0",
  "description": "Quickly decode (and encode) Base64 text right from your toolbar.",
  "permissions": ["contextMenus", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Base64 Decoder",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
